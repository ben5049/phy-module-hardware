			)
		)
		(uuid "5caa4b99-9aa3-49a0-aa6f-a5e7e10586e6")
	)
	(text_box "Since 3V3_AON and 3V3 are both derived from the efuse, if ~{FLT} is asserted it should be logged to the MCU EEPROM immediately since shutdown is imminent."
		(exclude_from_sim no)
		(at 172.72 40.64 0)
		(size 30.48 15.24)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
