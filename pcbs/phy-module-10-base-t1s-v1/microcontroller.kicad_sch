			)
			(justify left)
		)
		(uuid "74a2c911-a2cb-4899-a55e-ea821aaccb01")
	)
	(text_box "SLEEP\nLED"
		(exclude_from_sim no)
		(at 93.98 152.4 0)
		(size 10.16 5.08)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
