		(uuid "0ff9bf40-0944-46a9-9b46-d5e13f3deca9")
	)
	(text_box "PA0 is SYSWKUP1. However WAKE is shared with BOOT, and so to prevent waking up from standby also putting the MCU in bootloader mode, it cannot be used. Instead the lowest power mode available is STOP, which allows WFI on PB9."
		(exclude_from_sim no)
		(at 91.44 38.1 0)
		(size 33.02 17.78)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "20535a72-ad06-4e99-ba11-8c5cc570c6d4")
	)
	(text_box "PB9 is BOOT0:\n\nLOW = flash boot\nHIGH = system memory boot (bootloader)"
		(exclude_from_sim no)
		(at 134.62 99.06 0)
		(size 30.48 12.7)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "214229f5-7cf3-43a5-97c8-0fcecb238567")
	)
	(text_box "FAULT\nLED"
		(exclude_from_sim no)
		(at 124.46 152.4 0)
		(size 10.16 5.08)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
