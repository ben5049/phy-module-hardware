			)
		)
		(uuid "75c9204e-9909-4c38-a63f-4dae774137d5")
	)
	(text_box "All LEDs should be connected to open drain MCU outputs.\n\nNote: ~{FLT} is also connected to efuse OD output."
		(exclude_from_sim no)
		(at 68.58 170.18 0)
		(size 33.02 12.7)
